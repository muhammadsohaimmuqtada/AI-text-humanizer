# Security
AIP_API_KEY=change-me

# Input guardrails
AIP_ALLOWED_INPUT_ROOTS=/srv/aip-data,/tmp
AIP_MAX_TEXT_CHARS=25000
AIP_MAX_FILE_SIZE_MB=300

# Rate limiting
AIP_RATE_LIMIT_PER_MIN=60
AIP_RATE_LIMIT_BURST=20

# Observability
AIP_ENABLE_METRICS=true
AIP_ENABLE_AUDIT_LOG=true
AIP_AUDIT_LOG_PATH=/tmp/aip_audit.jsonl
AIP_CALIBRATION_FILE=/srv/aip-data/calibration.json

# CORS (enable only when needed)
AIP_ENABLE_CORS=false
AIP_CORS_ORIGINS=https://your-app.example.com
